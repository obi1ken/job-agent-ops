# Personal data (user fills these)
# NOTE: This is a personal fork — user-layer files ARE committed here.
# cv.md and data/ files intentionally tracked.
# data/scan-history.tsv excluded (auto-generated, large)
data/scan-history.tsv
reports/*.md
!reports/.gitkeep
output/*
!output/.gitkeep
batch/logs/*
!batch/logs/.gitkeep
batch/batch-state.tsv
batch/batch-input.tsv
batch/tracker-additions/**/*.tsv
!batch/tracker-additions/.gitkeep
jds/*
!jds/.gitkeep

# User config and customization (never auto-updated)
# NOTE: Personal fork — these ARE committed intentionally.
# config/profile.yml, portals.yml, modes/_profile.md tracked here.
.update-dismissed
.update-lock

# Secrets (never commit — use .env.example as template)
.env
extensions/email_monitor/credentials.json
extensions/email_monitor/token.json
extensions/email_monitor/poll_state.json

# Generated
.resolved-prompt-*
node_modules/
bun.lock

# OS
.DS_Store
*.mov
*.mp4

# Claude Code local
.claude/settings.local.json
.claude/memory/
career-dashboard
package-lock.json